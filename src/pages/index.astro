        <a href="https://twitter.com/IwanWilliamsSOM" aria-label="Twitter/X" class="text-white/50 hover:text-brand-accent transition-colors">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
    <div>
      <h4 class="font-display font-bold text-white mb-4">Navigation</h4>
      <ul class="space-y-2 text-sm text-white/70">
        <li><a href="/D1919" class="hover:text-brand-accent transition-colors">Home</a></li>
        <li><a href="/D1919/index-php-book-now" class="hover:text-brand-accent transition-colors">Prices &amp; Book Now</a></li>
        <li><a href="/D1919/index-php-automatic-driving-lessons" class="hover:text-brand-accent transition-colors">Automatic Lessons</a></li>
